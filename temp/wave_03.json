      "@DataWarehouse.tableFunction.script": "return select\n\tMAIN.KEYDATE,\n\tMAIN.INTERVAL1PLUSDATE,\n\tMAIN.INTERVAL1MINUSDATE,\n\tMAIN.INTERVAL2PLUSDATE,\n\tMAIN.INTERVAL2MINUSDATE,\n\tMAIN.INTERVAL3PLUSDATE,\n\tMAIN.INTERVAL3MINUSDATE,\n\tMAIN.INTERVAL4PLUSDATE,\n\tMAIN.INTERVAL4MINUSDATE,\n\tcase\n\t\twhen MAIN.NETDUEINTERVAL1INDAYS = 0 then 0\n\t\twhen MAIN.NETDUEINTERVAL2INDAYS = 0 then 1\n\t\twhen MAIN.NETDUEINTERVAL3INDAYS = 0 then 2\n\t\twhen MAIN.NETDUEINTERVAL4INDAYS = 0 then 3\n\t\telse 4\n\tend as NUMBEROFINTERVALS\nfrom ZSNAP_F01G_PARAMETERMATERIALIZATION(:P_KEYDATE, :P_NETDUEINTERVAL1INDAYS, :P_NETDUEINTERVAL2INDAYS, :P_NETDUEINTERVAL3INDAYS, :P_NETDUEINTERVAL4INDAYS) as MAIN;",
