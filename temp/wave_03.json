      "@DataWarehouse.tableFunction.script": "return select\n\tMAIN.COMPANYCODE,\n\tMAIN.FISCALYEAR,\n\tMAIN.ACCOUNTINGDOCUMENT,\n\tMAIN.LEDGERGLLINEITEM,\n\tMAIN.ACCOUNTINGDOCUMENTITEM,\n\tMAIN.DOCUMENTITEMTEXT,\n\tMAIN.ACCOUNTINGDOCUMENTCATEGORY,\n\tMAIN.ACCOUNTINGDOCUMENTTYPE,\n\tMAIN.CONTROLLINGAREA,\n\tMAIN.CHARTOFACCOUNTS,\n\tMAIN.FISCALYEARVARIANT,\n\tMAIN.INVOICEREFERENCE,\n\tMAIN.INVOICEITEMREFERENCE,\n\tMAIN.INVOICEREFERENCEFISCALYEAR,\n\tMAIN.CLEARINGJOURNALENTRY,\n\tMAIN.CLEARINGJOURNALENTRYFISCALYEAR,\n\tMAIN.DEBITCREDITCODE,\n\tMAIN.CLEARINGDATE,\n\tMAIN.POSTINGDATE,\n\tMAIN.DOCUMENTDATE,\n\tMAIN.DUECALCULATIONBASEDATE,\n\tMAIN.CASHDISCOUNT1DAYS,\n\tMAIN.CASHDISCOUNT1PERCENT,\n\tMAIN.DISCOUNTISAVAILABLE,\n\tMAIN.CASHDISCOUNT1DATE,\n\tMAIN.CASHDISCOUNT2DAYS,\n\tMAIN.CASHDISCOUNT2PERCENT,\n\tMAIN.CASHDISCOUNT2DATE,\n\tMAIN.PAYMENTBLOCKINGREASON,\n\tMAIN.PAYMENTMETHOD,\n\tMAIN.ISUSEDINPAYMENTTRANSACTION,\n\tMAIN.TREASURYCONTRACTTYPE,\n\tMAIN.FINANCIALACCOUNTTYPE,\n\tMAIN.SUPPLIER,\n\tMAIN.INVOICEREFERENCETYPE,\n\tMAIN.NETDUEDATE,\n\tMAIN.USEREFERENCEDINVOICEDATES,\n\tMAIN.SPECIALGLCODE,\n\tMAIN.GLACCOUNT,\n\tMAIN.COSTCENTER,\n\tMAIN.PROFITCENTER,\n\tMAIN.FUNCTIONALAREA,\n\tMAIN.BUSINESSAREA,\n\tMAIN.PARTNERCOMPANY,\n\tMAIN.SEGMENT,\n\tMAIN.PURCHASINGDOCUMENT,\n\tMAIN.ASSIGNMENTREFERENCE,\n\tMAIN.PAYMENTTERMS,\n\tMAIN.POSTINGKEY,\n\t\n\t/*@Semantics.amount.currencyCode: 'TransactionCurrency'*/\n\tMAIN.AMOUNTINTRANSACTIONCURRENCY,\n\t\n\t/*@Semantics.amount.currencyCode: 'TransactionCurrency'*/\n\tcast (cast (MAIN.AMOUNTINTRANSACTIONCURRENCY as DECIMAL(23,2)) * MAIN.CASHDISCOUNT1MULTIPLIER as DECIMAL(23,2)) as CASHDISCOUNT1INTC,\n\t\n\t/*@Semantics.amount.currencyCode: 'TransactionCurrency'*/\n\tcast (cast (MAIN.AMOUNTINTRANSACTIONCURRENCY as DECIMAL(23,2)) * MAIN.CASHDISCOUNT2MULTIPLIER as DECIMAL(23,2)) as CASHDISCOUNT2INTC,\n\tMAIN.TRANSACTIONCURRENCY,\n\t\n\t/*@Semantics.amount.currencyCode: 'BalanceTransactionCurrency'*/\n\tMAIN.AMOUNTINBALTC,\n\t\n\t/*@Semantics.amount.currencyCode: 'BalanceTransactionCurrency'*/\n\tcast (cast (MAIN.AMOUNTINBALTC as DECIMAL(23,2)) * MAIN.CASHDISCOUNT1MULTIPLIER as DECIMAL(23,2)) as CASHDISCOUNT1INBALTC,\n\t\n\t/*@Semantics.amount.currencyCode: 'BalanceTransactionCurrency'*/\n\tcast (cast (MAIN.AMOUNTINBALTC as DECIMAL(23,2)) * MAIN.CASHDISCOUNT2MULTIPLIER as DECIMAL(23,2)) as CASHDISCOUNT2INBALTC,\n\tMAIN.BALANCETRANSACTIONCURRENCY,\n\t\n\t/*@Semantics.amount.currencyCode: 'CompanyCodeCurrency'*/\n\tMAIN.AMOUNTINCOMPANYCODECURRENCY,\n\t\n\t/*@Semantics.amount.currencyCode: 'CompanyCodeCurrency'*/\n\tcast (cast (MAIN.AMOUNTINCOMPANYCODECURRENCY as DECIMAL(23,2)) * MAIN.CASHDISCOUNT1MULTIPLIER as DECIMAL(23,2)) as CASHDISCOUNT1INCC,\n\t\n\t/*@Semantics.amount.currencyCode: 'CompanyCodeCurrency'*/\n\tcast (cast (MAIN.AMOUNTINCOMPANYCODECURRENCY as DECIMAL(23,2)) * MAIN.CASHDISCOUNT2MULTIPLIER as DECIMAL(23,2)) as CASHDISCOUNT2INCC,\n\tMAIN.COMPANYCODECURRENCY,\n\t\n\t/*@Semantics.amount.currencyCode: 'GlobalCurrency'*/\n\tMAIN.AMOUNTINGLOBALCURRENCY,\n\t\n\t/*@Semantics.amount.currencyCode: 'GlobalCurrency'*/\n\tcast (cast (MAIN.AMOUNTINGLOBALCURRENCY as DECIMAL(23,2)) * MAIN.CASHDISCOUNT1MULTIPLIER as DECIMAL(23,2)) as CASHDISCOUNT1INGC,\n\t\n\t/*@Semantics.amount.currencyCode: 'GlobalCurrency'*/\n\tcast (cast (MAIN.AMOUNTINGLOBALCURRENCY as DECIMAL(23,2)) * MAIN.CASHDISCOUNT2MULTIPLIER as DECIMAL(23,2)) as CASHDISCOUNT2INGC,\n\tMAIN.GLOBALCURRENCY\nfrom ZSNAP_F01S_050(:P_SIGNAGE, :P_KEYDATE) as MAIN;",
      "@Analytics.dbViewType": "TABLE_FUNCTION",
      "@EndUserText.label": "SNAP F01: Discount Calculations"
    },
