      "@DataWarehouse.businessDefinition.description": "Computes base discount amounts by multiplying invoice amounts by discount percentages. These raw discount values feed downstream available, missed, and claimed discount calculations.",
      "@DataWarehouse.businessDefinition.purpose": "Calculates raw CashDiscount1/2 amounts in all currency types from discount multipliers",
      "@DataWarehouse.businessDefinition.contact": "Egan Bosch",
      "@DataWarehouse.businessDefinition.responsibleTeam": "Artisan Edge, Inc.",
      "_meta": {
        "dependencies": {
          "folderAssignment": "Folder_YBEQBWWQ"
        }
      },
      "params": {
        "P_SIGNAGE": {
          "@Consumption.defaultValue": "R",
          "@EndUserText.label": "Signage",
          "@Consumption.valueHelpDefinition": [
            {
              "entity": {
                "name": "ZSNAP_F01C_P_SIGNAGE",
                "element": "P_SIGNAGE"
              }
            }
          ],
