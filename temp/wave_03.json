      "@DataWarehouse.tableFunction.script": "return select\n\tMAIN.ACCOUNTINGDOCUMENT,\n\tMAIN.COMPANYCODE,\n\tMAIN.FISCALYEAR,\n\tMAIN.LEDGER,\n\tMAIN.LEDGERGLLINEITEM,\n\tMAIN.SOURCELEDGER,\n\tMAIN.ACCOUNTINGDOCUMENTTYPE,\n\tMAIN.ACCOUNTINGDOCUMENTCATEGORY,\n\tMAIN.ACCOUNTINGDOCUMENTITEM,\n\tMAIN.CLEARINGJOURNALENTRY,\n\tMAIN.CLEARINGJOURNALENTRYFISCALYEAR,\n\tMAIN.CLEARINGDATE,\n\tMAIN.SPECIALGLCODE,\n\tMAIN.BUSINESSAREA,\n\tMAIN.CHARTOFACCOUNTS,\n\tMAIN.CONTROLLINGAREA,\n\tMAIN.COSTCENTER,\n\tMAIN.DEBITCREDITCODE,\n\tMAIN.FINANCIALACCOUNTTYPE,\n\tMAIN.FUNCTIONALAREA,\n\tMAIN.GLACCOUNT,\n\tcase MAIN.ACCOUNTINGDOCUMENTCATEGORY\n\t\twhen 'J' then case MAIN.FISCALPERIOD\n\t\t\twhen '000' then cast ('X' as NVARCHAR(1))\n\t\t\telse cast ('' as NVARCHAR(1))\n\t\tend\n\t\telse 'X'\n\tend as ISSTARTINGBALANCERELEVANT,\n\tMAIN.PROFITCENTER,\n\tcase _FISCALYEARPERIOD.ISSPECIALPERIOD\n\t\twhen 'X' then _FISCALYEARPERIOD_FISCALPERIODSTARTDATE.FISCALPERIOD\n\t\telse MAIN.FISCALPERIOD\n\tend as FISCALPERIOD,\n\tMAIN.FISCALYEARVARIANT,\n\tMAIN.SUPPLIER,\n\t\n\t/*@Semantics.amount.currencyCode: 'TransactionCurrency'*/\n\tcast (MAIN.AMOUNTINTRANSACTIONCURRENCY as DECIMAL(23,2)) as AMOUNTINTRANSACTIONCURRENCY,\n\tMAIN.TRANSACTIONCURRENCY,\n\t\n\t/*@Semantics.amount.currencyCode: 'CompanyCodeCurrency'*/\n\tcast (MAIN.AMOUNTINCOMPANYCODECURRENCY as DECIMAL(23,2)) as AMOUNTINCOMPANYCODECURRENCY,\n\tMAIN.COMPANYCODECURRENCY,\n\t\n\t/*@Semantics.amount.currencyCode: 'GlobalCurrency'*/\n\tcast (MAIN.AMOUNTINGLOBALCURRENCY as DECIMAL(23,2)) as AMOUNTINGLOBALCURRENCY,\n\tMAIN.GLOBALCURRENCY\nfrom ZSNAP_F01G_GLACCOUNTLINEITEM as MAIN\nleft outer join ZSNAP_F01G_FISCALYEARPERIOD as _FISCALYEARPERIOD on MAIN.FISCALYEARVARIANT = _FISCALYEARPERIOD.FISCALYEARVARIANT and MAIN.FISCALYEARPERIOD = _FISCALYEARPERIOD.FISCALYEARPERIOD\nleft outer join ZSNAP_F01G_FISCALCALENDARDATE as _FISCALYEARPERIOD_FISCALPERIODSTARTDATE on TO_VARCHAR (_FISCALYEARPERIOD.FISCALPERIODSTARTDATE, 'YYYYMMDD') = TO_VARCHAR (_FISCALYEARPERIOD_FISCALPERIODSTARTDATE.CALENDARDATE, 'YYYYMMDD') and _FISCALYEARPERIOD.FISCALYEARVARIANT = _FISCALYEARPERIOD_FISCALPERIODSTARTDATE.FISCALYEARVARIANT\nwhere MAIN.FISCALYEARPERIOD <= :P_STOFISCALYEARPERIOD\n\tand MAIN.FISCALYEAR >= :P_SFROMFISCALYEAR;",
      "@Analytics.dbViewType": "TABLE_FUNCTION",
      "@EndUserText.label": "SNAP F72: Balance Derivation Basis"
    },
