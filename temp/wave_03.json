      "@DataWarehouse.tableFunction.script": "return select\n\tMAIN.ACCOUNTINGDOCUMENT,\n\tMAIN.COMPANYCODE,\n\tMAIN.FISCALYEAR,\n\tMAIN.LEDGER,\n\tMAIN.LEDGERGLLINEITEM,\n\tMAIN.SOURCELEDGER,\n\tMAIN.ACCOUNTINGDOCUMENTTYPE,\n\tMAIN.ACCOUNTINGDOCUMENTCATEGORY,\n\tMAIN.ACCOUNTINGDOCUMENTITEM,\n\tMAIN.CLEARINGJOURNALENTRY,\n\tMAIN.CLEARINGJOURNALENTRYFISCALYEAR,\n\tMAIN.CLEARINGDATE,\n\tMAIN.SPECIALGLCODE,\n\tMAIN.BUSINESSAREA,\n\tMAIN.CHARTOFACCOUNTS,\n\tMAIN.CONTROLLINGAREA,\n\tMAIN.COSTCENTER,\n\tMAIN.DEBITCREDITCODE,\n\tMAIN.FINANCIALACCOUNTTYPE,\n\tMAIN.FUNCTIONALAREA,\n\tMAIN.GLACCOUNT,\n\tMAIN.PROFITCENTER,\n\tMAIN.SUPPLIER,\n\tMAIN.FISCALPERIOD as SPECIALPERIOD,\n\tMAIN.FISCALYEARPERIOD,\n\t\n\t/*@Semantics.fiscal.yearVariant: true*/\n\tMAIN.FISCALYEARVARIANT,\n\t\n\t/*@Semantics.amount.currencyCode: 'TransactionCurrency'*/\n\tcast (0 as DECIMAL(23,2)) as ENDINGBALANCEAMTINTRANSCRCY,\n\tMAIN.TRANSACTIONCURRENCY,\n\t\n\t/*@Semantics.amount.currencyCode: 'CompanyCodeCurrency'*/\n\tcast (0 as DECIMAL(23,2)) as ENDINGBALANCEAMTINCOCODECRCY,\n\tMAIN.COMPANYCODECURRENCY,\n\t\n\t/*@Semantics.amount.currencyCode: 'GlobalCurrency'*/\n\tcast (0 as DECIMAL(23,2)) as ENDINGBALANCEAMTINGLOBALCRCY,\n\tMAIN.GLOBALCURRENCY\nfrom ZSNAP_F01G_GLACCOUNTLINEITEM as MAIN\nwhere MAIN.FISCALYEARPERIOD <= :P_STOFISCALYEARPERIOD\n\tand MAIN.FISCALYEAR >= :P_SFROMFISCALYEAR\n\tand MAIN.ACCOUNTINGDOCUMENTCATEGORY <> 'J'\n\tand MAIN.FISCALPERIOD <> '000';",
      "@Analytics.dbViewType": "TABLE_FUNCTION",
      "@EndUserText.label": "SNAP F72: Financial Balances Basis"
    },
