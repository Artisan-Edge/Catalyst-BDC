      "@DataWarehouse.tableFunction.script": "return select\n\tMAIN.COMPANYCODE,\n\tMAIN.FISCALYEAR,\n\tMAIN.ACCOUNTINGDOCUMENT,\n\tMAIN.LEDGERGLLINEITEM,\n\tMAIN.ACCOUNTINGDOCUMENTITEM,\n\tMAIN.DOCUMENTITEMTEXT,\n\tMAIN.ACCOUNTINGDOCUMENTCATEGORY,\n\tMAIN.ACCOUNTINGDOCUMENTTYPE,\n\t_ACCOUNTINGDOCUMENTTYPETEXT.ACCOUNTINGDOCUMENTTYPENAME,\n\tMAIN.INVOICEREFERENCE,\n\tMAIN.INVOICEREFERENCETYPE,\n\tMAIN.INVOICEITEMREFERENCE,\n\tMAIN.INVOICEREFERENCEFISCALYEAR,\n\tMAIN.DEBITCREDITCODE,\n\tMAIN.CLEARINGJOURNALENTRY,\n\tMAIN.CLEARINGJOURNALENTRYFISCALYEAR,\n\t_JOURNALENTRY.\"AccountingDocumentHeaderText\" as ACCOUNTINGDOCUMENTHEADERTEXT,\n\t_JOURNALENTRY.\"DocumentReferenceID\" as DOCUMENTREFERENCEID,\n\t_JOURNALENTRY.\"AccountingDocumentCreationDate\" as ACCOUNTINGDOCUMENTCREATIONDATE,\n\t_JOURNALENTRY.\"LastChangeDate\" as LASTCHANGEDATE,\n\tMAIN.FINANCIALACCOUNTTYPE,\n\tMAIN.POSTINGDATE,\n\t_CALENDARDATE.CALENDARMONTH,\n\t_CALENDARDATE.CALENDARQUARTER,\n\t_CALENDARDATE.CALENDARWEEK,\n\t_CALENDARDATE.CALENDARYEAR,\n\t_FISCALCALENDARDATE.FISCALPERIOD,\n\tTO_VARCHAR (_FISCALCALENDARDATE.FISCALPERIODENDDATE, 'YYYYMMDD') as FISCALPERIODENDDATE,\n\t_FISCALCALENDARDATE.FISCALQUARTER,\n\t_FISCALCALENDARDATE.FISCALYEARPERIOD,\n\t_FISCALCALENDARDATE.FISCALYEARQUARTER,\n\t_CLEARINGFISCALCALENDARDATE.FISCALYEAR as CLEARINGFISCALYEAR,\n\t_CLEARINGFISCALCALENDARDATE.FISCALPERIOD as CLEARINGFISCALPERIOD,\n\t_CLEARINGFISCALCALENDARDATE.FISCALQUARTER as CLEARINGFISCALQUARTER,\n\t_CLEARINGFISCALCALENDARDATE.FISCALYEARPERIOD as CLEARINGFISCALYEARPERIOD,\n\t_CLEARINGFISCALCALENDARDATE.FISCALYEARQUARTER as CLEARINGFISCALYEARQUARTER,\n\tMAIN.CLEARINGDATE,\n\tMAIN.DOCUMENTDATE,\n\tMAIN.DUECALCULATIONBASEDATE,\n\tMAIN.CASHDISCOUNT1DAYS,\n\tMAIN.CASHDISCOUNT1PERCENT,\n\tMAIN.CASHDISCOUNT1DATE,\n\tMAIN.CASHDISCOUNT2DAYS,\n\tMAIN.CASHDISCOUNT2PERCENT,\n\tMAIN.CASHDISCOUNT2DATE,\n\tMAIN.DISCOUNTISAVAILABLE,\n\tMAIN.CASHDISCOUNTMISSED,\n\tMAIN.PAYMENTTERMS,\n\tMAIN.PAYMENTBLOCKINGREASON,\n\t_PAYMENTBLOCKINGREASONTEXT.PAYMENTBLOCKINGREASONNAME,\n\tMAIN.PAYMENTMETHOD,\n\tMAIN.ISUSEDINPAYMENTTRANSACTION,\n\tMAIN.TREASURYCONTRACTTYPE,\n\tMAIN.POSTINGKEY,\n\t_POSTINGKEYTEXT.POSTINGKEYNAME,\n\tMAIN.NETDUEARREARSDAYS,\n\tMAIN.NETDUEARREARSDAYSINT,\n\tMAIN.NETDUEDATE,\n\tMAIN.GLACCOUNT,\n\tcast ('ZMED' as NVARCHAR(42)) as GLACCOUNTHIERARCHY,\n\t_GLACCOUNTLEVELS.GLACCTLEVEL1,\n\t_GLACCOUNTLEVELS.GLACCTLEVEL2,\n\t_GLACCOUNTLEVELS.GLACCTLEVEL3,\n\t_GLACCOUNTLEVELS.GLACCTLEVEL4,\n\t_GLACCOUNTLEVELS.GLACCTLEVEL5,\n\t_GLACCOUNT.CORPORATEGROUPACCOUNT,\n\t_GLACCOUNT.CORPORATEGROUPCHARTOFACCOUNTS,\n\tMAIN.SPECIALGLCODE,\n\tMAIN.COSTCENTER,\n\tMAIN.PROFITCENTER,\n\tMAIN.BUSINESSAREA,\n\tMAIN.FUNCTIONALAREA,\n\tMAIN.SEGMENT,\n\tMAIN.PURCHASINGDOCUMENT,\n\t_PURCHASEORDER.PAYMENTTERMS as POPAYMENTTERMS,\n\tcase\n\t\twhen _PURCHASEORDER.PAYMENTTERMS <> MAIN.PAYMENTTERMS then 'X'\n\t\telse cast ('' as NVARCHAR(1))\n\tend as POPAYMENTTERMSDIFFER,\n\tMAIN.ASSIGNMENTREFERENCE,\n\tMAIN.SUPPLIER,\n\t_SUPPLIER.ORGANIZATIONBPNAME1 as SUPPLIERNAME,\n\t_SUPPLIER.COUNTRY as SUPPLIERCOUNTRY,\n\t_SUPPLIER.REGION as SUPPLIERREGION,\n\t_SUPPLIERCOMPANY.\"AccountingClerk\" as ACCOUNTINGCLERK,\n\t_SUPPLIERCOMPANY.\"ReconciliationAccount\" as RECONCILIATIONACCOUNT,\n\t_SUPPLIER.AUTHORIZATIONGROUP as SUPPLIERBASICAUTHORIZATIONGRP,\n\t_SUPPLIERCOMPANY.\"AuthorizationGroup\" as SUPPLIERFINSAUTHORIZATIONGRP,\n\t_SUPPLIER.SUPPLIERACCOUNTGROUP,\n\t_INTERCOMPANYSUPPLIER.SUPPLIERISINTERCOMPANY,\n\tMAIN.PARTNERCOMPANY,\n\tcase\n\t\twhen _INTERCOMPANYSUPPLIER.PARTNERCOMPANYCODE = '' then cast ('' as NVARCHAR(1))\n\t\twhen MAIN.COMPANYCODE < _INTERCOMPANYSUPPLIER.PARTNERCOMPANYCODE then CONCAT (MAIN.COMPANYCODE, CONCAT ('-', _INTERCOMPANYSUPPLIER.PARTNERCOMPANYCODE))\n\t\telse CONCAT (_INTERCOMPANYSUPPLIER.PARTNERCOMPANYCODE, CONCAT ('-', MAIN.COMPANYCODE))\n\tend as INTERCOMPANYPAIRING,\n\tMAIN.CHARTOFACCOUNTS,\n\tMAIN.CONTROLLINGAREA,\n\tMAIN.FISCALYEARVARIANT,\n\tMAIN.CLEARINGDATEVSDUEDATEOFFSET,\n\tMAIN.PAYMENTTIMINGCATEGORY,\n\tMAIN.ISOVERDUE,\n\tMAIN.DAYSOVERDUE,\n\tMAIN.DAYSOVERDUEINT,\n\tMAIN.ISCLEARED,\n\tMAIN.NETDUEINTERVALTEXT,\n\tcase\n\t\twhen MAIN.AMOUNTINDISPLAYCURRENCY is null and MAIN.AMOUNTINCOMPANYCODECURRENCY <> 0 then 'X'\n\t\telse cast ('' as NVARCHAR(1))\n\tend as ISCONVERSIONBROKEN,\n\t:P_INCLUDESPECIALGL as INCLUDESPECIALGL,\n\t:P_SIGNAGE as SIGNAGE,\n\t\n\t/*@Semantics.amount.currencyCode: 'TransactionCurrency'*/\n\tMAIN.AMOUNTINTRANSACTIONCURRENCY,\n\t\n\t/*@Semantics.amount.currencyCode: 'TransactionCurrency'*/\n\tMAIN.CASHDISCOUNT1INTC,\n\t\n\t/*@Semantics.amount.currencyCode: 'TransactionCurrency'*/\n\tMAIN.CASHDISCOUNT2INTC,\n\t\n\t/*@Semantics.amount.currencyCode: 'TransactionCurrency'*/\n\tMAIN.AVAILABLEDISCOUNTINTC,\n\t\n\t/*@Semantics.amount.currencyCode: 'TransactionCurrency'*/\n\tMAIN.MISSEDDISCOUNTINTC,\n\t\n\t/*@Semantics.amount.currencyCode: 'TransactionCurrency'*/\n\tMAIN.CLAIMEDDISCOUNTINTC,\n\t\n\t/*@Semantics.amount.currencyCode: 'TransactionCurrency'*/\n\tMAIN.OPENAMTINTRANSACTIONCURRENCY,\n\t\n\t/*@Semantics.amount.currencyCode: 'TransactionCurrency'*/\n\tMAIN.PYCLEAREDINTRANSACTIONCURRENCY,\n\tMAIN.TRANSACTIONCURRENCY,\n\t\n\t/*@Semantics.amount.currencyCode: 'BalanceTransactionCurrency'*/\n\tMAIN.AMOUNTINBALTC,\n\t\n\t/*@Semantics.amount.currencyCode: 'BalanceTransactionCurrency'*/\n\tMAIN.CASHDISCOUNT1INBALTC,\n\t\n\t/*@Semantics.amount.currencyCode: 'BalanceTransactionCurrency'*/\n\tMAIN.CASHDISCOUNT2INBALTC,\n\t\n\t/*@Semantics.amount.currencyCode: 'BalanceTransactionCurrency'*/\n\tMAIN.AVAILABLEDISCOUNTINBALTC,\n\t\n\t/*@Semantics.amount.currencyCode: 'BalanceTransactionCurrency'*/\n\tMAIN.MISSEDDISCOUNTINBALTC,\n\t\n\t/*@Semantics.amount.currencyCode: 'BalanceTransactionCurrency'*/\n\tMAIN.CLAIMEDDISCOUNTINBALTC,\n\t\n\t/*@Semantics.amount.currencyCode: 'BalanceTransactionCurrency'*/\n\tMAIN.OPENAMTINBALTC,\n\t\n\t/*@Semantics.amount.currencyCode: 'BalanceTransactionCurrency'*/\n\tMAIN.PYCLEAREDINBALTC,\n\tMAIN.BALANCETRANSACTIONCURRENCY,\n\t\n\t/*@Semantics.amount.currencyCode: 'CompanyCodeCurrency'*/\n\tMAIN.AMOUNTINCOMPANYCODECURRENCY,\n\t\n\t/*@Semantics.amount.currencyCode: 'CompanyCodeCurrency'*/\n\tMAIN.CASHDISCOUNT1INCC,\n\t\n\t/*@Semantics.amount.currencyCode: 'CompanyCodeCurrency'*/\n\tMAIN.CASHDISCOUNT2INCC,\n\t\n\t/*@Semantics.amount.currencyCode: 'CompanyCodeCurrency'*/\n\tMAIN.AVAILABLEDISCOUNTINCC,\n\t\n\t/*@Semantics.amount.currencyCode: 'CompanyCodeCurrency'*/\n\tMAIN.MISSEDDISCOUNTINCC,\n\t\n\t/*@Semantics.amount.currencyCode: 'CompanyCodeCurrency'*/\n\tMAIN.CLAIMEDDISCOUNTINCC,\n\t\n\t/*@Semantics.amount.currencyCode: 'CompanyCodeCurrency'*/\n\tMAIN.OPENAMTINCOMPANYCODECURRENCY,\n\t\n\t/*@Semantics.amount.currencyCode: 'CompanyCodeCurrency'*/\n\tMAIN.PYCLEAREDINCOMPANYCODECURRENCY,\n\tMAIN.COMPANYCODECURRENCY,\n\t\n\t/*@Semantics.amount.currencyCode: 'GlobalCurrency'*/\n\tMAIN.AMOUNTINGLOBALCURRENCY,\n\t\n\t/*@Semantics.amount.currencyCode: 'GlobalCurrency'*/\n\tMAIN.CASHDISCOUNT1INGC,\n\t\n\t/*@Semantics.amount.currencyCode: 'GlobalCurrency'*/\n\tMAIN.CASHDISCOUNT2INGC,\n\t\n\t/*@Semantics.amount.currencyCode: 'GlobalCurrency'*/\n\tMAIN.AVAILABLEDISCOUNTINGC,\n\t\n\t/*@Semantics.amount.currencyCode: 'GlobalCurrency'*/\n\tMAIN.MISSEDDISCOUNTINGC,\n\t\n\t/*@Semantics.amount.currencyCode: 'GlobalCurrency'*/\n\tMAIN.CLAIMEDDISCOUNTINGC,\n\t\n\t/*@Semantics.amount.currencyCode: 'GlobalCurrency'*/\n\tMAIN.OPENAMTINGLOBALCURRENCY,\n\t\n\t/*@Semantics.amount.currencyCode: 'GlobalCurrency'*/\n\tMAIN.PYCLEAREDINGLOBALCURRENCY,\n\tMAIN.GLOBALCURRENCY,\n\t\n\t/*@Semantics.amount.currencyCode: 'DisplayCurrency'*/\n\tMAIN.AMOUNTINDISPLAYCURRENCY,\n\t\n\t/*@Semantics.amount.currencyCode: 'DisplayCurrency'*/\n\tMAIN.CASHDISCOUNT1INDC,\n\t\n\t/*@Semantics.amount.currencyCode: 'DisplayCurrency'*/\n\tMAIN.CASHDISCOUNT2INDC,\n\t\n\t/*@Semantics.amount.currencyCode: 'DisplayCurrency'*/\n\tMAIN.AVAILABLEDISCOUNTINDC,\n\t\n\t/*@Semantics.amount.currencyCode: 'DisplayCurrency'*/\n\tMAIN.MISSEDDISCOUNTINDC,\n\t\n\t/*@Semantics.amount.currencyCode: 'DisplayCurrency'*/\n\tMAIN.CLAIMEDDISCOUNTINDC,\n\t\n\t/*@Semantics.amount.currencyCode: 'DisplayCurrency'*/\n\tMAIN.OPENAMTINDISPLAYCURRENCY,\n\t\n\t/*@Semantics.amount.currencyCode: 'DisplayCurrency'*/\n\tMAIN.PYCLEAREDINDISPLAYCURRENCY,\n\tMAIN.DISPLAYCURRENCY\nfrom ZSNAP_F01S_303(:P_SIGNAGE, :P_KEYDATE, :P_CLEAREDDATE, :P_NETDUEINTERVAL1INDAYS, :P_NETDUEINTERVAL2INDAYS, :P_NETDUEINTERVAL3INDAYS, :P_NETDUEINTERVAL4INDAYS, :P_DISPLAYCURRENCY, :P_EXCHANGERATETYPE, :P_EARLYPAYMENTTOLERANCEDAYS) as MAIN\nleft outer join I_JOURNALENTRY as _JOURNALENTRY on MAIN.COMPANYCODE = _JOURNALENTRY.\"CompanyCode\" and MAIN.FISCALYEAR = _JOURNALENTRY.\"FiscalYear\" and MAIN.ACCOUNTINGDOCUMENT = _JOURNALENTRY.\"AccountingDocument\"\nleft outer join I_SUPPLIERCOMPANY as _SUPPLIERCOMPANY on MAIN.COMPANYCODE = _SUPPLIERCOMPANY.\"CompanyCode\" and MAIN.SUPPLIER = _SUPPLIERCOMPANY.\"Supplier\"\nleft outer join ZSNAP_F01G_129 as _GLACCOUNTLEVELS on (_GLACCOUNTLEVELS.GLACCOUNTHIERARCHY = 'ZMED' and MAIN.CHARTOFACCOUNTS = _GLACCOUNTLEVELS.CHARTOFACCOUNTS and MAIN.GLACCOUNT = _GLACCOUNTLEVELS.GLACCOUNT and _GLACCOUNTLEVELS.VALIDITYENDDATE = '99991231') and _GLACCOUNTLEVELS.VALIDITYENDDATE >= current_date\nleft outer join ZSNAP_F01G_ACCOUNTINGDOCUMENTTYPETEXT as _ACCOUNTINGDOCUMENTTYPETEXT on MAIN.ACCOUNTINGDOCUMENTTYPE = _ACCOUNTINGDOCUMENTTYPETEXT.ACCOUNTINGDOCUMENTTYPE and _ACCOUNTINGDOCUMENTTYPETEXT.LANGUAGE = 'E'\nleft outer join ZSNAP_F01G_CALENDARDATE as _CALENDARDATE on MAIN.POSTINGDATE = TO_VARCHAR (_CALENDARDATE.CALENDARDATE, 'YYYYMMDD')\nleft outer join ZSNAP_F01G_FISCALCALENDARDATE as _CLEARINGFISCALCALENDARDATE on MAIN.FISCALYEARVARIANT = _CLEARINGFISCALCALENDARDATE.FISCALYEARVARIANT and MAIN.CLEARINGDATE = TO_VARCHAR (_CLEARINGFISCALCALENDARDATE.CALENDARDATE, 'YYYYMMDD')\nleft outer join ZSNAP_F01G_FISCALCALENDARDATE as _FISCALCALENDARDATE on MAIN.FISCALYEARVARIANT = _FISCALCALENDARDATE.FISCALYEARVARIANT and MAIN.POSTINGDATE = TO_VARCHAR (_FISCALCALENDARDATE.CALENDARDATE, 'YYYYMMDD')\nleft outer join ZSNAP_F01G_GLACCOUNTINCHARTOFACCOUNTS as _GLACCOUNT on MAIN.GLACCOUNT = _GLACCOUNT.GLACCOUNT and MAIN.CHARTOFACCOUNTS = _GLACCOUNT.CHARTOFACCOUNTS\nleft outer join ZSNAP_F01G_PAYMENTBLOCKINGREASONTEXT as _PAYMENTBLOCKINGREASONTEXT on MAIN.PAYMENTBLOCKINGREASON = _PAYMENTBLOCKINGREASONTEXT.PAYMENTBLOCKINGREASON and _PAYMENTBLOCKINGREASONTEXT.LANGUAGE = 'E'\nleft outer join ZSNAP_F01G_POSTINGKEYTEXT as _POSTINGKEYTEXT on MAIN.POSTINGKEY = _POSTINGKEYTEXT.POSTINGKEY and _POSTINGKEYTEXT.LANGUAGE = 'E'\nleft outer join ZSNAP_F01G_PURCHASEORDER as _PURCHASEORDER on MAIN.PURCHASINGDOCUMENT = _PURCHASEORDER.PURCHASEORDER\nleft outer join ZSNAP_F01G_SUPPLIER as _SUPPLIER on MAIN.SUPPLIER = _SUPPLIER.SUPPLIER\nleft outer join ZSNAP_F01M_INTERCOMPANYSUPPLIER as _INTERCOMPANYSUPPLIER on MAIN.SUPPLIER = _INTERCOMPANYSUPPLIER.SUPPLIER;",
      "@Analytics.dbViewType": "TABLE_FUNCTION",
      "@EndUserText.label": "SNAP F01: Derivation Layer"
    }
