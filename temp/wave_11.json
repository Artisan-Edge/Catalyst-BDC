      "@DataWarehouse.tableFunction.script": "return select\n\t/*@EndUserText.label: 'Company Code'*/\n\tMAIN.COMPANYCODE,\n\t\n\t/*@EndUserText.label: 'Fiscal Year'*/\n\tMAIN.FISCALYEAR,\n\t\n\t/*@EndUserText.label: 'Journal Entry'*/\n\tMAIN.ACCOUNTINGDOCUMENT,\n\t\n\t/*@EndUserText.label: 'Ledger GL Line Item'*/\n\tMAIN.LEDGERGLLINEITEM,\n\t\n\t/*@EndUserText.label: 'Journal Entry Item'*/\n\tMAIN.ACCOUNTINGDOCUMENTITEM,\n\t\n\t/*@EndUserText.label: 'Journal Entry Category'*/\n\tMAIN.ACCOUNTINGDOCUMENTCATEGORY,\n\t\n\t/*@EndUserText.label: 'Journal Entry Type'*/\n\tMAIN.ACCOUNTINGDOCUMENTTYPE,\n\t\n\t/*@EndUserText.label: 'Debit/Credit Indicator'*/\n\tMAIN.DEBITCREDITCODE,\n\t\n\t/*@EndUserText.label: 'Clearing Journal Entry'*/\n\tMAIN.CLEARINGJOURNALENTRY,\n\t\n\t/*@EndUserText.label: 'Clearing Journal Entry Fiscal Year'*/\n\tMAIN.CLEARINGJOURNALENTRYFISCALYEAR,\n\t\n\t/*@EndUserText.label: 'Chart of Accounts'*/\n\tMAIN.CHARTOFACCOUNTS,\n\t\n\t/*@EndUserText.label: 'Controlling Area'*/\n\tMAIN.CONTROLLINGAREA,\n\t\n\t/*@EndUserText.label: 'Fiscal Year Period'*/\n\tMAIN.FISCALYEARPERIOD,\n\t\n\t/*@EndUserText.label: 'Fiscal Period End Date'*/\n\tTO_DATE (MAIN.FISCALPERIODENDDATE, 'YYYYMMDD') as FISCALPERIODENDDATE,\n\t\n\t/*@EndUserText.label: 'Selected Fiscal Year Period'*/\n\tMAIN.SELECTEDYEARPERIOD,\n\t\n\t/*@EndUserText.label: 'Key Date'*/\n\tTO_DATE (MAIN.KEYDATE, 'YYYYMMDD') as KEYDATE,\n\t\n\t/*@EndUserText.label: 'Fiscal Year Variant'*/\n\tMAIN.FISCALYEARVARIANT,\n\t\n\t/*@EndUserText.label: 'Financial Account Type'*/\n\tMAIN.FINANCIALACCOUNTTYPE,\n\t\n\t/*@EndUserText.label: 'Clearing Date'*/\n\tMAIN.CLEARINGDATE,\n\t\n\t/*@EndUserText.label: 'Payment Terms'*/\n\tMAIN.PAYMENTTERMS,\n\t\n\t/*@EndUserText.label: 'Supplier'*/\n\tMAIN.SUPPLIER,\n\t\n\t/*@EndUserText.label: 'Supplier Account Group'*/\n\tMAIN.SUPPLIERACCOUNTGROUP,\n\t\n\t/*@EndUserText.label: 'GL Account'*/\n\tMAIN.GLACCOUNT,\n\t\n\t/*@EndUserText.label: 'Group Account'*/\n\tMAIN.CORPORATEGROUPACCOUNT,\n\t\n\t/*@EndUserText.label: 'Group Chart of Accounts'*/\n\tMAIN.CORPORATEGROUPCHARTOFACCOUNTS,\n\t\n\t/*@EndUserText.label: 'Supplier Reconciliation Account'*/\n\tMAIN.RECONCILIATIONACCOUNT,\n\t\n\t/*@EndUserText.label: 'Special GL Code'*/\n\tMAIN.SPECIALGLCODE,\n\t\n\t/*@EndUserText.label: 'Cost Center'*/\n\tMAIN.COSTCENTER,\n\t\n\t/*@EndUserText.label: 'Profit Center'*/\n\tMAIN.PROFITCENTER,\n\t\n\t/*@EndUserText.label: 'Functional Area'*/\n\tMAIN.FUNCTIONALAREA,\n\t\n\t/*@EndUserText.label: 'Business Area'*/\n\tMAIN.BUSINESSAREA,\n\t\n\t/*@EndUserText.label: 'Recon Source'*/\n\tMAIN.RECONSOURCE,\n\t\n\t/*@EndUserText.label: 'Signage'\n\t@SNAP.masterdata.values: [['A', 'Payments Are Positive'], ['R', 'Open AP is Positive']]*/\n\tMAIN.SIGNAGE,\n\t\n\t/*@DefaultAggregation: #SUM\n\t@EndUserText.label: 'Number Of Rows'*/\n\tcast (1 as DECIMAL(12,0)) as NUMBEROFROWS,\n\t\n\t/*@DefaultAggregation: #SUM\n\t@EndUserText.label: 'AP Amt in TC'\n\t@Semantics.amount.currencyCode: 'TransactionCurrency'*/\n\tMAIN.AMOUNTINTRANSACTIONCURRENCY,\n\t\n\t/*@DefaultAggregation: #SUM\n\t@EndUserText.label: 'GL Bal in TC'\n\t@Semantics.amount.currencyCode: 'TransactionCurrency'*/\n\tMAIN.BALAMTINTC,\n\t\n\t/*@EndUserText.label: 'Transaction Currency'*/\n\tMAIN.TRANSACTIONCURRENCY,\n\t\n\t/*@DefaultAggregation: #SUM\n\t@EndUserText.label: 'AP Amt in LC'\n\t@Semantics.amount.currencyCode: 'CompanyCodeCurrency'*/\n\tMAIN.AMOUNTINCOMPANYCODECURRENCY,\n\t\n\t/*@DefaultAggregation: #SUM\n\t@EndUserText.label: 'GL Bal in LC'\n\t@Semantics.amount.currencyCode: 'CompanyCodeCurrency'*/\n\tMAIN.BALAMTINCC,\n\t\n\t/*@EndUserText.label: 'Local Currency'*/\n\tMAIN.COMPANYCODECURRENCY,\n\t\n\t/*@DefaultAggregation: #SUM\n\t@EndUserText.label: 'AP Amt in GC'\n\t@Semantics.amount.currencyCode: 'GlobalCurrency'*/\n\tMAIN.AMOUNTINGLOBALCURRENCY,\n\t\n\t/*@DefaultAggregation: #SUM\n\t@EndUserText.label: 'GL Bal in GC'\n\t@Semantics.amount.currencyCode: 'GlobalCurrency'*/\n\tMAIN.BALAMTINGC,\n\t\n\t/*@EndUserText.label: 'Group Currency'*/\n\tMAIN.GLOBALCURRENCY\nfrom ZSNAP_F01S_507(:P_KEYDATE, :P_SIGNAGE, :P_FISCALYEAR, :P_FISCALYEARPERIOD) as MAIN;",
